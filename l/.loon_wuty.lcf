[Remote Filter]
# 节点
全球·节点 = NameRegex, FilterKey = "^(?=.*)(?!.*(邀请|返利|循环|官网|客服|网站|网址|获取|订阅|流量|到期|机场|下次|版本|官址|备用|恢复|过期|已用|联系|邮箱|Traffic|工单|群|贩卖|通知|倒卖|防止|国内|校园|实验|实验性|游戏|🎮|TG|GAME|USE|USED|TOTAL|EXPIRE|EMAIL|Panel|CN|China|zju|zju_cn)).+$"
大陆·节点 = NameRegex, FilterKey = "^(?=.*((?i)大陆|回国|(\b(CN|China|cn|zju|zju(_cn)?)\b)))(?!.*((?i)校园)).*$"
浙大·节点 = NameRegex, FilterKey = "^(?=.*((?i)浙大|(\b(zju(_cn)?)\b)))(?!.*((?i)校园)).*$"
香港·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇭🇰|香港|(\b(HK|Hong)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
台湾·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇹🇼|台湾|(\b(TW|Tai|Taiwan)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
日本·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇯🇵|日本|川日|东京|大阪|泉日|埼玉|(\b(JP|Japan)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
韩国·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇰🇷|韩国|韓|首尔|(\b(KR|Korea)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
新国·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇸🇬|新加坡|狮|(\b(SG|Singapore)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
美国·节点 = NameRegex, FilterKey = "^(?=.*((?i)🇺🇸|美国|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|(\b(US|United States)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
直连·节点 = NameRegex, FilterKey = "^(?=.*((?i)直连|(\b(AD)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"
拒绝·节点 = NameRegex, FilterKey = "^(?=.*((?i)广告|(\b(AD)\b)))(?!.*((?i)回国|校园|实验|游戏|🎮|(\b(GAME)\b))).*$"

